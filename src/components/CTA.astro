---
import { getTranslations } from '../i18n';

// Get locale from URL path - /en/ for English, / for Chinese
const path = Astro.url.pathname;
const currentLocale = path.startsWith('/en') ? 'en' : 'zh';
const t = getTranslations(currentLocale);

// Split title by \n for line breaks
const titleLines = t.cta.title.split('\\n');
---

<section class="cta-section section" id="cta">
  <div class="container">
    <div class="island cta-island">
      <div class="cta-section__orb" aria-hidden="true"></div>
      <div class="cta-section__inner">
        <div class="cta-section__content">
          <span class="tag tag--orange" style="margin-bottom: 20px; display: inline-flex;">{t.cta.tag}</span>
          <h2 class="cta-section__title">
            {titleLines.map((line, i) => (
              <span>{line}<br /></span>
            ))}
          </h2>
          <p class="cta-section__desc">
            {t.cta.description}
          </p>
          <div class="cta-section__actions">
            <a href="#pricing" class="btn btn--primary" style="font-size: 16px; padding: 16px 36px;">
              {t.cta.cta}
            </a>
            <a href="#how-it-works" class="btn btn--ghost" style="font-size: 16px; padding: 16px 36px;">
              {t.cta.demo}
            </a>
          </div>
          <p class="cta-section__note">{t.cta.note}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    /* transparent — stripe shows through */
  }

  .cta-island {
    background: var(--gray-50);
    overflow: hidden;
    position: relative;
    padding: 48px 40px; /* Tighter vertical spacing */
  }

  .cta-section__orb {
    position: absolute;
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(232, 81, 26, 0.1) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .cta-section__inner {
    position: relative;
    z-index: 1;
  }

  .cta-section__content {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-section__title {
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 20px;
    color: var(--black);
  }

  .cta-section__desc {
    font-size: 17px;
    color: var(--gray-500);
    line-height: 1.75;
    margin-bottom: 36px;
    max-width: 480px;
  }

  .cta-section__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 20px;
  }

  .cta-section__note {
    font-size: 13px;
    color: var(--gray-400);
  }

  @media (max-width: 768px) {
    .cta-island {
      padding: 40px 16px;
    }
  }
</style>
