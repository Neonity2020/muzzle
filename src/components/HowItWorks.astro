---
import { getTranslations } from '../i18n';

// Get locale from URL path - /en/ for English, / for Chinese
const path = Astro.url.pathname;
const currentLocale = path.startsWith('/en') ? 'en' : 'zh';
const t = getTranslations(currentLocale);

const steps = t.howItWorks.steps.map((step, i) => ({
  ...step,
  color: ['#E8511A', '#6366F1', '#10B981', '#F59E0B'][i],
  visual: i === 0 ? 'chat' : 'settings',
}));
---

<section class="how-it-works section" id="how-it-works">
  <div class="container">
    <div class="island">
    <div class="hiw__header">
      <p class="section-eyebrow">{t.howItWorks.eyebrow}</p>
      <h2 class="section-title">{t.howItWorks.title.replace('\\n', '<br />')}</h2>
      <p class="section-desc">{t.howItWorks.description}</p>
    </div>

    <!-- Step tabs -->
    <div class="hiw__tabs" role="tablist">
      {steps.map((step, i) => (
        <button
          class:list={['hiw__tab', i === 0 && 'active']}
          role="tab"
          aria-selected={i === 0}
          aria-controls={`step-panel-${i}`}
          id={`step-tab-${i}`}
          data-index={i}
          style={`--step-color: ${step.color}`}
        >
          <span class="hiw__tab-num">{step.num}</span>
          <span class="hiw__tab-label">{step.title}</span>
        </button>
      ))}
    </div>

    <!-- Step panels -->
    <div class="hiw__panels">
      {steps.map((step, i) => (
        <div
          class:list={['hiw__panel', i === 0 && 'active']}
          role="tabpanel"
          id={`step-panel-${i}`}
          aria-labelledby={`step-tab-${i}`}
        >
          <div class="hiw__panel-content">
            <div class="hiw__panel-text">
              <span class="hiw__step-badge" style={`background: ${step.color}20; color: ${step.color}`}>
                {t.howItWorks.step} {step.num}
              </span>
              <h3 class="hiw__panel-title">{step.subtitle}</h3>
              <p class="hiw__panel-desc">{step.description}</p>
              <a href={step.linkText === t.howItWorks.steps[0].linkText ? '#contact' : step.linkText === t.howItWorks.steps[1].linkText ? '#features' : '#pricing'} class="btn btn--primary" style={`background: ${step.color}`}>
                {step.linkText}
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>

            <div class="hiw__panel-visual">
              {step.visual === 'chat' && (
                <div class="hiw__visual-chat">
                  <div class="hiw__chat-msg hiw__chat-msg--ai">
                    <div class="hiw__chat-avatar">
                      <svg width="16" height="16" viewBox="0 0 32 32" fill="none">
                        <rect width="32" height="32" rx="8" fill="white"/>
                        <path d="M8 22L14 10L20 18L23 14L24 22" stroke="#E8511A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                    <div class="hiw__chat-bubble">{step.chatMsg1}</div>
                  </div>
                  <div class="hiw__chat-msg hiw__chat-msg--user">
                    <div class="hiw__chat-bubble">{step.chatMsg2}</div>
                  </div>
                  <div class="hiw__chat-msg hiw__chat-msg--system">
                    <div class="hiw__chat-bubble">{step.chatMsg3}</div>
                  </div>
                  <div class="hiw__chat-typing">
                    <span></span><span></span><span></span>
                  </div>
                </div>
              )}
              {step.visual === 'settings' && (
                <div class="hiw__visual-settings">
                  <div class="hiw__settings-title">{t.howItWorks.settings.title}</div>
                  {[
                    { label: t.howItWorks.settings.pref1, on: true },
                    { label: t.howItWorks.settings.pref2, on: true },
                    { label: t.howItWorks.settings.pref3, on: false },
                    { label: t.howItWorks.settings.pref4, on: true },
                    { label: t.howItWorks.settings.pref5, on: true },
                  ].map(pref => (
                    <div class="hiw__pref">
                      <span class="hiw__pref-label">{pref.label}</span>
                      <span class:list={['hiw__toggle', pref.on && 'on']}></span>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
    </div>
  </div>
</section>

<style>
  .hiw__header {
    text-align: center;
    margin-bottom: 56px;
  }

  .hiw__tabs {
    display: flex;
    gap: 8px;
    background: var(--white);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: var(--radius-lg);
    padding: 8px;
    margin-bottom: 32px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .hiw__tabs::-webkit-scrollbar { display: none; }

  .hiw__tab {
    flex: 1;
    min-width: 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 14px 16px;
    border-radius: var(--radius-md);
    border: none;
    background: transparent;
    color: var(--gray-500);
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .hiw__tab:hover {
    background: var(--gray-50);
    color: var(--black);
  }

  .hiw__tab.active {
    background: var(--step-color, var(--orange));
    color: white;
  }

  .hiw__tab-num {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    opacity: 0.7;
  }

  .hiw__tab-label {
    font-size: 14px;
    font-weight: 600;
  }

  .hiw__panel {
    display: none;
  }

  .hiw__panel.active {
    display: block;
    animation: fadeInPanel 0.35s ease;
  }

  @keyframes fadeInPanel {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hiw__panel-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    background: white;
    border-radius: var(--radius-xl);
    border: 1px solid rgba(0,0,0,0.07);
    padding: 60px;
  }

  .hiw__step-badge {
    display: inline-block;
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    margin-bottom: 16px;
  }

  .hiw__panel-title {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .hiw__panel-desc {
    font-size: 15px;
    color: var(--gray-500);
    line-height: 1.75;
    margin-bottom: 28px;
  }

  .hiw__panel-visual {
    background: var(--gray-50);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(0,0,0,0.06);
    padding: 28px;
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Chat visual */
  .hiw__visual-chat {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .hiw__chat-msg {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .hiw__chat-msg--user {
    flex-direction: row-reverse;
  }

  .hiw__chat-avatar {
    width: 32px;
    height: 32px;
    border-radius: 10px;
    background: var(--orange);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hiw__chat-bubble {
    background: white;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 14px;
    padding: 12px 16px;
    font-size: 13px;
    color: var(--gray-700);
    line-height: 1.5;
    max-width: 80%;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .hiw__chat-msg--user .hiw__chat-bubble {
    background: var(--orange);
    color: white;
    border-color: transparent;
  }

  .hiw__chat-typing {
    display: flex;
    gap: 4px;
    padding: 12px 16px;
    background: white;
    border-radius: 14px;
    border: 1px solid rgba(0,0,0,0.08);
    width: fit-content;
  }

  .hiw__chat-typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gray-300);
    animation: typingBounce 1.2s ease-in-out infinite;
  }

  .hiw__chat-typing span:nth-child(2) { animation-delay: 0.2s; }
  .hiw__chat-typing span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-4px); }
  }

  /* Settings visual */
  .hiw__visual-settings {
    width: 100%;
  }

  .hiw__settings-title {
    font-weight: 700;
    margin-bottom: 16px;
    font-size: 14px;
  }

  .hiw__pref {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 0;
    border-bottom: 1px solid var(--gray-100);
    font-size: 14px;
    color: var(--gray-700);
  }

  .hiw__pref:last-child {
    border-bottom: none;
  }

  .hiw__toggle {
    width: 40px;
    height: 22px;
    border-radius: 100px;
    background: var(--gray-200);
    position: relative;
    flex-shrink: 0;
    transition: background 0.2s;
  }

  .hiw__toggle::after {
    content: '';
    position: absolute;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: white;
    top: 3px;
    left: 3px;
    transition: transform 0.2s;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  }

  .hiw__toggle.on {
    background: #10B981;
  }

  .hiw__toggle.on::after {
    transform: translateX(18px);
  }

  @media (max-width: 768px) {
    .hiw__panel-content {
      grid-template-columns: 1fr;
      padding: 28px 16px;
      gap: 32px;
    }

    .hiw__panel-title {
      font-size: 24px;
    }

    .hiw__panel-visual {
      padding: 16px;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.hiw__tab');
  const panels = document.querySelectorAll<HTMLElement>('.hiw__panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const idx = Number(tab.dataset.index);

      tabs.forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach(p => p.classList.remove('active'));

      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      panels[idx]?.classList.add('active');
    });
  });
</script>
