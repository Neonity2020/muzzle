---
import { getTranslations } from '../i18n';

// Get locale from URL path - /en/ for English, / for Chinese
const path = Astro.url.pathname;
const currentLocale = path.startsWith('/en') ? 'en' : 'zh';
const t = getTranslations(currentLocale);

const plans = t.pricing.plans.map((plan, i) => ({
  ...plan,
  featured: i === 1,
  tag: i === 1 ? t.pricing.mostPopular : '',
  price: i === 2 ? 'Custom' : i === 1 ? '399' : '99',
}));
---

<section class="pricing section" id="pricing">
  <div class="container">
    <div class="island">
    <div class="pricing__header">
      <p class="section-eyebrow">{t.pricing.eyebrow}</p>
      <h2 class="section-title">{t.pricing.title.replace('\\n', '<br />')}</h2>
      <p class="section-desc">{t.pricing.description}</p>
      <p class="section-desc" style="margin: 0 auto">{t.pricing.trialNote}</p>

      <!-- Toggle -->
      <div class="pricing__toggle">
        <span class="pricing__toggle-label" id="label-monthly">{t.pricing.monthly}</span>
        <button class="pricing__toggle-btn" id="billing-toggle" aria-label="Toggle billing period" aria-pressed="false">
          <span class="pricing__toggle-thumb"></span>
        </button>
        <span class="pricing__toggle-label" id="label-annual">
          {t.pricing.annual}
          <span class="pricing__toggle-save">{t.pricing.save}</span>
        </span>
      </div>
    </div>

    <!-- Pricing cards -->
    <div class="pricing__grid">
      {plans.map((plan, i) => (
        <div class:list={['pricing-card', plan.featured && 'pricing-card--featured']} data-animate style={`--delay: ${i * 100}ms`}>
          {plan.tag && (
            <div class="pricing-card__tag">{plan.tag}</div>
          )}
          <div class="pricing-card__header">
            <div class="pricing-card__name">{plan.name}</div>
            <div class="pricing-card__desc">{plan.desc}</div>
          </div>
          <div class="pricing-card__price">
            <span class="pricing-card__amount" data-monthly={plan.price} data-annual={plan.price === 'Custom' ? 'Custom' : `¥${parseInt(plan.price) * 0.8 | 0}`}>
              {plan.price}
            </span>
            <span class="pricing-card__period">{plan.interval}</span>
          </div>
          <a href="#" class:list={['btn', plan.featured ? 'btn--primary' : 'btn--ghost']}>
            {plan.cta}
          </a>
          <ul class="pricing-card__features">
            {plan.features.map(f => (
              <li class="pricing-card__feature">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="pricing-card__check" aria-hidden="true">
                  <circle cx="8" cy="8" r="8" fill={plan.featured ? 'rgba(255,255,255,0.2)' : 'rgba(16,185,129,0.15)'}/>
                  <path d="M5 8l2 2 4-4" stroke={plan.featured ? 'white' : '#10B981'} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Enterprise note -->
    <div class="pricing__enterprise">
      <p>{t.pricing.contactEnterprise}
        <a href="#" class="pricing__enterprise-link">{t.pricing.contactSales} →</a>
      </p>
    </div>
    </div>
  </div>
</section>

<style>
  .pricing__header {
    text-align: center;
    margin-bottom: 56px;
  }

  .pricing__toggle {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-top: 32px;
    background: white;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 100px;
    padding: 8px 20px;
  }

  .pricing__toggle-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--gray-500);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pricing__toggle-save {
    background: var(--orange-pale);
    color: var(--orange);
    font-size: 11px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 100px;
  }

  .pricing__toggle-btn {
    width: 44px;
    height: 24px;
    background: var(--gray-200);
    border-radius: 100px;
    position: relative;
    transition: background 0.2s;
    flex-shrink: 0;
    cursor: pointer;
  }

  .pricing__toggle-btn.on {
    background: var(--orange);
  }

  .pricing__toggle-thumb {
    position: absolute;
    width: 18px;
    height: 18px;
    background: white;
    border-radius: 50%;
    top: 3px;
    left: 3px;
    transition: transform 0.2s;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  }

  .pricing__toggle-btn.on .pricing__toggle-thumb {
    transform: translateX(20px);
  }

  .pricing__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    align-items: start;
  }

  .pricing-card {
    background: white;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: var(--radius-lg);
    padding: 36px;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 24px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease var(--delay, 0ms), transform 0.5s ease var(--delay, 0ms), box-shadow 0.2s ease;
  }

  .pricing-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .pricing-card:hover {
    box-shadow: 0 16px 48px rgba(0,0,0,0.1);
  }

  .pricing-card--featured {
    background: var(--black);
    color: white;
    border-color: transparent;
    transform: translateY(-8px);
    box-shadow: 0 24px 64px rgba(0,0,0,0.2);
  }

  .pricing-card--featured.visible {
    transform: translateY(-8px);
  }

  .pricing-card--featured:hover {
    box-shadow: 0 32px 80px rgba(0,0,0,0.25);
    transform: translateY(-12px);
  }

  .pricing-card__tag {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--orange);
    color: white;
    font-size: 11px;
    font-weight: 700;
    padding: 5px 16px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .pricing-card__name {
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }

  .pricing-card__desc {
    font-size: 13px;
    color: var(--gray-500);
    line-height: 1.5;
  }

  .pricing-card--featured .pricing-card__desc {
    color: rgba(255,255,255,0.5);
  }

  .pricing-card__price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    padding: 20px 0;
    border-top: 1px solid rgba(0,0,0,0.07);
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }

  .pricing-card--featured .pricing-card__price {
    border-color: rgba(255,255,255,0.1);
  }

  .pricing-card__amount {
    font-size: 48px;
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .pricing-card__period {
    font-size: 14px;
    color: var(--gray-400);
    font-weight: 500;
  }

  .pricing-card--featured .pricing-card__period {
    color: rgba(255,255,255,0.4);
  }

  .pricing-card__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pricing-card__feature {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--gray-700);
  }

  .pricing-card--featured .pricing-card__feature {
    color: rgba(255,255,255,0.8);
  }

  .pricing-card__check {
    flex-shrink: 0;
  }

  .pricing__enterprise {
    text-align: center;
    margin-top: 48px;
    font-size: 14px;
    color: var(--gray-500);
  }

  .pricing__enterprise-link {
    color: var(--orange);
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .pricing__enterprise-link:hover {
    opacity: 0.8;
  }

  @media (max-width: 900px) {
    .pricing__grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }

    .pricing-card {
      padding: 24px 16px;
    }

    .pricing-card--featured {
      transform: translateY(0);
    }

    .pricing-card--featured.visible {
      transform: translateY(0);
    }
  }
</style>

<script>
  const toggleBtn = document.getElementById('billing-toggle');
  let isAnnual = false;

  toggleBtn?.addEventListener('click', () => {
    isAnnual = !isAnnual;
    toggleBtn.classList.toggle('on', isAnnual);
    toggleBtn.setAttribute('aria-pressed', String(isAnnual));

    document.querySelectorAll<HTMLElement>('.pricing-card__amount').forEach(el => {
      el.textContent = isAnnual ? (el.dataset.annual || '') : (el.dataset.monthly || '');
    });
  });

  const pcards = document.querySelectorAll('.pricing-card[data-animate]');
  const pobs = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.1 });
  pcards.forEach(el => pobs.observe(el));
</script>
