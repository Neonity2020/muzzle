---
import { getTranslations } from '../i18n';

// Get locale from URL path - /en/ for English, / for Chinese
const path = Astro.url.pathname;
const currentLocale = path.startsWith('/en') ? 'en' : 'zh';
const t = getTranslations(currentLocale);

const testimonials = t.testimonials.items.map((item, i) => ({
  ...item,
  featured: i === 0,
  rating: 5,
  avatar: ['/avatars/1.png', '/avatars/2.png', '/avatars/3.png', '/avatars/4.png'][i],
  avatarColor: ['#E8511A', '#6366F1', '#10B981', '#F59E0B'][i],
}));
---

<section class="testimonials section" id="testimonials">
  <div class="container">
    <div class="island">
    <div class="testimonials__header">
      <p class="section-eyebrow">{t.testimonials.eyebrow}</p>
      <h2 class="section-title">{t.testimonials.title.replace('\\n', '<br />')}</h2>
      <p class="section-desc">{t.testimonials.description}</p>
    </div>

    <!-- Rating summary -->
    <div class="testimonials__summary">
      <div class="testimonials__rating-big">{t.testimonials.ratingBig}</div>
      <div class="testimonials__rating-info">
        <div class="testimonials__stars-big">★★★★★</div>
        <div class="testimonials__rating-text" set:html={t.testimonials.basedOnReviews} />
        <div class="testimonials__platforms">
          <span>G2 4.9</span>
          <span>Product Hunt #1</span>
          <span>Capterra 4.8</span>
        </div>
      </div>
    </div>

    <!-- Testimonial grid -->
    <div class="testimonials__grid">
      {testimonials.map((t_item, i) => (
        <div class:list={['testimonial-card', t_item.featured && 'testimonial-card--featured']} data-animate style={`--delay: ${i * 100}ms`}>
          {t_item.featured && (
            <div class="testimonial-card__badge">{t.testimonials.featuredBadge}</div>
          )}
          <div class="testimonial-card__stars">
            {'★'.repeat(t_item.rating)}
          </div>
          <p class="testimonial-card__quote">"{t_item.quote}"</p>
          <div class="testimonial-card__author">
            <img src={t_item.avatar} alt={t_item.name} class="testimonial-card__avatar" style={`background: ${t_item.avatarColor}`} />
            <div>
              <div class="testimonial-card__name">{t_item.name}</div>
              <div class="testimonial-card__role">{t_item.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
    </div>
  </div>
</section>

<style>
  .testimonials {
  }

  .testimonials__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .testimonials__summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin-bottom: 64px;
    padding: 32px;
    background: var(--gray-50);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(0,0,0,0.06);
  }

  .testimonials__rating-big {
    font-size: 72px;
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--black);
    line-height: 1;
  }

  .testimonials__stars-big {
    color: #FFB800;
    font-size: 20px;
    letter-spacing: 2px;
    margin-bottom: 4px;
  }

  .testimonials__rating-text {
    font-size: 14px;
    color: var(--gray-500);
    margin-bottom: 12px;
  }

  .testimonials__platforms {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .testimonials__platforms span {
    font-size: 12px;
    font-weight: 600;
    color: var(--gray-500);
    background: white;
    padding: 4px 12px;
    border-radius: 100px;
    border: 1px solid rgba(0,0,0,0.08);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .testimonial-card {
    background: var(--gray-50);
    border: 1px solid rgba(0,0,0,0.07);
    border-radius: var(--radius-lg);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease var(--delay, 0ms), transform 0.5s ease var(--delay, 0ms), box-shadow 0.2s ease;
  }

  .testimonial-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .testimonial-card:hover {
    box-shadow: 0 16px 48px rgba(0,0,0,0.1);
    transform: translateY(-3px);
  }

  .testimonial-card--featured {
    background: var(--black);
    color: white;
    border-color: transparent;
    grid-column: span 2;
  }

  .testimonial-card--featured .testimonial-card__quote {
    font-size: 20px;
    color: rgba(255,255,255,0.9);
  }

  .testimonial-card--featured .testimonial-card__role {
    color: rgba(255,255,255,0.5);
  }

  .testimonial-card__badge {
    font-size: 12px;
    font-weight: 600;
    color: var(--orange);
    background: rgba(232, 81, 26, 0.15);
    padding: 4px 12px;
    border-radius: 100px;
    width: fit-content;
  }

  .testimonial-card__stars {
    color: #FFB800;
    font-size: 16px;
    letter-spacing: 2px;
  }

  .testimonial-card__quote {
    font-size: 15px;
    line-height: 1.75;
    color: var(--gray-600);
    flex: 1;
  }

  .testimonial-card--featured .testimonial-card__stars {
    color: #FFD700;
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  .testimonial-card--featured .testimonial-card__author {
    border-top-color: rgba(255,255,255,0.1);
  }

  .testimonial-card__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 800;
    color: white;
    flex-shrink: 0;
    object-fit: cover;
  }

  .testimonial-card__name {
    font-weight: 700;
    font-size: 14px;
  }

  .testimonial-card__role {
    font-size: 12px;
    color: var(--gray-500);
  }

  @media (max-width: 768px) {
    .testimonials__grid {
      grid-template-columns: 1fr;
    }

    .testimonial-card {
      padding: 20px;
    }

    .testimonial-card--featured {
      grid-column: span 1;
    }

    .testimonials__summary {
      flex-direction: column;
      text-align: center;
      padding: 24px 12px;
    }

    .testimonials__platforms {
      justify-content: center;
    }
  }
</style>

<script>
  const tcards = document.querySelectorAll('.testimonial-card[data-animate]');
  const tobs = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.1 });
  tcards.forEach(el => tobs.observe(el));
</script>
