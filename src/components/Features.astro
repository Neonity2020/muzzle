---
import { getTranslations } from '../i18n';

// Get locale from URL path - /en/ for English, / for Chinese
const path = Astro.url.pathname;
const currentLocale = path.startsWith('/en') ? 'en' : 'zh';
const t = getTranslations(currentLocale);
---

<section class="features section" id="features">
  <div class="container">
    <div class="island">
    <!-- Section header -->
    <div class="features__header">
      <p class="section-eyebrow">{t.features.eyebrow}</p>
      <h2 class="section-title">{t.features.title.replace('\\n', '<br />')}</h2>
      <p class="section-desc">{t.features.description}</p>
    </div>

    <!-- Feature cards grid -->
    <div class="features__grid">
      {t.features.items.map((f, i) => (
        <div class="feature-card" data-animate style={`--delay: ${i * 80}ms`}>
          <div class="feature-card__icon-wrap" style={`background: ${['#FFF0EA', '#EEF2FF', '#ECFDF5', '#FFFBEB'][i]}; color: ${['#E8511A', '#6366F1', '#10B981', '#F59E0B'][i]}`}>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              {i === 0 && <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>}
              {i === 1 && <path d="M18 20V10M12 20V4M6 20v-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>}
              {i === 2 && <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>}
              {i === 3 && <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>}
            </svg>
          </div>
          <span class="feature-card__tag" style={`background: ${['#FFF0EA', '#EEF2FF', '#ECFDF5', '#FFFBEB'][i]}; color: ${['#E8511A', '#6366F1', '#10B981', '#F59E0B'][i]}`}>
            {f.tag}
          </span>
          <h3 class="feature-card__title">{f.title}</h3>
          <p class="feature-card__desc">{f.description}</p>

          <div class="feature-card__footer">
            <a href="#how-it-works" class="feature-card__link" style={`color: ${['#E8511A', '#6366F1', '#10B981', '#F59E0B'][i]}`}>
              {t.features.learnMore}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Big feature banner -->
    <div class="features__banner stripe-bg" data-animate>
      <div class="features__banner-content">
        <p class="section-eyebrow">{t.features.banner.eyebrow}</p>
        <h3 class="features__banner-title">{t.features.banner.title.replace('\\n', '<br />')}</h3>
        <p class="features__banner-desc">{t.features.banner.description}</p>
        <a href="#pricing" class="btn btn--primary" style="margin-top: 24px">{t.features.banner.cta}</a>
      </div>
      <div class="features__banner-visual">
        <div class="features__integration-grid">
          {t.features.integrations.map(int => (
            <div class="features__integration-chip">
              <span class="features__integration-name">{int.name}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
    </div>
  </div>
</section>

<style>
  .features__header {
    text-align: center;
    margin-bottom: 64px;
  }

  .features__header .section-desc {
    margin: 0 auto;
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 20px;
  }

  .feature-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(0,0,0,0.07);
    padding: 36px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease var(--delay, 0ms), transform 0.5s ease var(--delay, 0ms), box-shadow 0.2s ease;
  }

  .feature-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .feature-card:hover {
    box-shadow: 0 20px 60px rgba(0,0,0,0.1);
    transform: translateY(-4px);
  }

  .feature-card__icon-wrap {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .feature-card__tag {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    width: fit-content;
  }

  .feature-card__title {
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--black);
    margin-top: 4px;
  }

  .feature-card__desc {
    font-size: 15px;
    color: var(--gray-500);
    line-height: 1.7;
    flex: 1;
  }

  .feature-card__footer {
    padding-top: 8px;
    border-top: 1px solid var(--gray-100);
    margin-top: 8px;
  }

  .feature-card__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    transition: gap 0.2s ease;
  }

  .feature-card__link:hover {
    gap: 10px;
  }

  /* Banner */
  .features__banner {
    border-radius: var(--radius-xl);
    border: 1px solid rgba(0,0,0,0.07);
    background: var(--gray-50);
    padding: 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    overflow: hidden;
    position: relative;
  }

  .features__banner::before {
    content: '';
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(232, 81, 26, 0.08) 0%, transparent 70%);
    top: -100px;
    right: 200px;
    pointer-events: none;
  }

  .features__banner-title {
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 16px;
    color: var(--black);
  }

  .features__banner-desc {
    font-size: 15px;
    color: var(--gray-500);
    line-height: 1.7;
  }

  .features__integration-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .features__integration-chip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: white;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 12px;
    padding: 12px 14px;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .features__integration-chip:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    transform: scale(1.03);
  }

  .features__integration-name {
    font-size: 12px;
    font-weight: 600;
    color: var(--gray-700);
  }

  @media (max-width: 768px) {
    .features__grid {
      grid-template-columns: 1fr;
    }

    .feature-card {
      padding: 20px;
    }

    .features__banner {
      grid-template-columns: 1fr;
      padding: 32px 12px;
      gap: 36px;
    }

    .features__banner-title {
      font-size: 28px;
    }
  }
</style>

<script>
  const featureCards = document.querySelectorAll('[data-animate]');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  featureCards.forEach(el => observer.observe(el));
</script>
